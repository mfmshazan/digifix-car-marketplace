# ================================
# Docker Environment Variables
# ================================
# Copy this file to .env and update the values

# ================================
# PostgreSQL Configuration
# ================================
POSTGRES_USER=digifix
POSTGRES_PASSWORD=digifix123
POSTGRES_DB=digifix_db
POSTGRES_PORT=5432

# ================================
# Backend Configuration
# ================================
NODE_ENV=development
BACKEND_PORT=3000

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Frontend URL for CORS
FRONTEND_URL=*

# ================================
# Database URLs (auto-generated in docker-compose)
# ================================
# These are automatically set in docker-compose.yml
# DATABASE_URL=postgresql://digifix:digifix123@postgres:5432/digifix_db?schema=public
# DIRECT_URL=postgresql://digifix:digifix123@postgres:5432/digifix_db?schema=public
