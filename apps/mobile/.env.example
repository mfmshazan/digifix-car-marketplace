# Clerk Configuration
# Get your publishable key from the Clerk Dashboard: https://dashboard.clerk.com
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Optional: your computer's LAN IP (Expo Go on a device). Used when Metro's hostUri
# is not ready yet after a reload so API + profile image URLs stay correct.
# EXPO_PUBLIC_LOCAL_IP=192.168.1.10
