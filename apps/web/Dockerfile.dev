# Development Dockerfile for Next.js Web Application
FROM node:20-alpine

WORKDIR /app

# Install dependencies for hot-reloading and native modules
RUN apk add --no-cache libc6-compat python3 make g++

# Copy package files
COPY package*.json ./

# Install dependencies with retry to handle flaky network
RUN npm install || npm install || npm install

# Copy source code
COPY . .

# Expose port
EXPOSE 3001

# Start development server
CMD ["npm", "run", "dev"]
