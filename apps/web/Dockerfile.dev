# Development Dockerfile for Next.js Web Application
FROM node:20-alpine

WORKDIR /app

# Install dependencies for hot-reloading
RUN apk add --no-cache libc6-compat

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Expose port
EXPOSE 3001

# Start development server
CMD ["npm", "run", "dev"]
