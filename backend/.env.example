# Database URL from Neon
# Get this from your Neon dashboard: https://console.neon.tech
DATABASE_URL="postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# JWT Secret for authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Clerk (for Google Sign-In)
CLERK_SECRET_KEY="your-clerk-secret-key"

# Server configuration
PORT=3000
NODE_ENV=development

FRONTEND_URL="http://localhost:8081"

# Optional: force cancellation-request push notifications to one admin user id
# If omitted, backend falls back to the first admin account in DB
ADMIN_NOTIFICATION_USER_ID=""

# Email Configuration (Forgot Password Flow)
EMAIL_PROVIDER="resend"
FALLBACK_EMAIL_PROVIDER="sendgrid"
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxx"
OTP_EXPIRY_MINUTES="10"
EMAIL_FROM="noreply@yourdomain.com"


