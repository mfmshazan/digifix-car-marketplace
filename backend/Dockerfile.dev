# Development Dockerfile with hot-reloading support
FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
COPY prisma ./prisma/

RUN npm install

# Generate Prisma Client
RUN npx prisma generate

# Copy source code
COPY . .

# Expose port
EXPOSE 3000

# Start with nodemon for hot-reloading
# Also run prisma generate at startup so schema changes via volume mount are picked up
CMD ["sh", "-c", "npx prisma generate && npm run dev"]
