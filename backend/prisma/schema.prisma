// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enum for user roles
enum UserRole {
  CUSTOMER
  SALESMAN
  ADMIN
  RIDER
}

// Enum for user status
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// Enum for authentication provider
enum AuthProvider {
  EMAIL
  GOOGLE
}

// User model
model User {
  id           String       @id @default(cuid())
  email        String       @unique
  password     String? // Nullable for Google auth users
  name         String?
  phone        String?
  avatar       String?
  role         UserRole     @default(CUSTOMER)
  authProvider AuthProvider @default(EMAIL)
  googleId     String?      @unique
  isVerified   Boolean      @default(false)
  status       UserStatus   @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  addresses Address[]
  orders    Order[]        @relation("CustomerOrders")
  cart      CartItem[]
  wishlist  WishlistItem[]
  reviews   Review[]

  // Salesman specific relations
  products    Product[] @relation("SalesmanProducts")
  salesOrders Order[]   @relation("SalesmanOrders")
  store       Store?
  carParts    CarPart[] @relation("SellerCarParts")

  @@index([email])
  @@index([role])
}

// Store model for salesmen
model Store {
  id          String   @id @default(cuid())
  name        String
  description String?
  logo        String?
  banner      String?
  address     String?
  phone       String?
  rating      Float    @default(0)
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  ownerId  String    @unique
  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([ownerId])
}

// Product model
model Product {
  id            String   @id @default(cuid())
  name          String
  description   String?
  price         Float
  discountPrice Float?
  sku           String?  @unique
  stock         Int      @default(0)
  images        String[]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  salesmanId String
  salesman   User   @relation("SalesmanProducts", fields: [salesmanId], references: [id], onDelete: Cascade)

  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  orderItems    OrderItem[]
  reviews       Review[]

  // Vehicle compatibility
  compatibleVehicles VehicleCompatibility[]

  @@index([categoryId])
  @@index([salesmanId])
  @@index([storeId])
  @@index([name])
}

// Category model
model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  icon        String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  products Product[]
  carParts CarPart[]

  @@index([parentId])
}

// Vehicle compatibility for parts
model VehicleCompatibility {
  id        String  @id @default(cuid())
  make      String // e.g., Toyota, Honda
  model     String // e.g., Camry, Civic
  yearStart Int // Starting year
  yearEnd   Int? // Ending year (null means current)
  engine    String? // Engine type if specific

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([make, model])
  @@index([productId])
}

// Address model
model Address {
  id         String   @id @default(cuid())
  label      String? // e.g., "Home", "Office"
  street     String
  city       String
  state      String
  postalCode String
  country    String   @default("Sri Lanka")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

// Cart item model
model CartItem {
  id        String   @id @default(cuid())
  quantity  Int      @default(1)
  itemType  String   @default("PRODUCT") // PRODUCT or CAR_PART
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Can reference either Product or CarPart
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  carPartId String?
  carPart   CarPart? @relation(fields: [carPartId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@unique([userId, carPartId])
  @@index([userId])
}

// Wishlist item model
model WishlistItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Relations
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  itemType  String   @default("PRODUCT") // PRODUCT or CAR_PART

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  carPartId String?
  carPart   CarPart? @relation(fields: [carPartId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@unique([userId, carPartId])
  @@index([userId])
}

// Tracks the lifecycle of an order from placement through delivery or cancellation
enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  REFUND_REQUESTED
  AVAILABLE
  ASSIGNED
  ACCEPTED
  ARRIVED_AT_PICKUP
  PICKED_UP
  IN_TRANSIT
  ARRIVED_AT_DROPOFF
  FAILED
}

// Payment status enum
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// Each order belongs to one seller — multi-seller carts create multiple orders
model Order {
  id                 String        @id @default(cuid())
  orderNumber        String        @unique @default(cuid())
  status             OrderStatus   @default(PENDING)
  paymentStatus      PaymentStatus @default(PENDING)
  paymentMethod      String?
  subtotal           Float
  serviceCharge      Float         @default(0) // 10% platform fee charged to customer
  deliveryFee        Float         @default(0) // Calculated as distance_km * 250 once distance is available
  discount           Float         @default(0)
  total              Float
  notes              String?
  cancellationReason String?       // Customer must provide a reason so admin can make an informed decision
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Relations
  customerId String
  customer   User   @relation("CustomerOrders", fields: [customerId], references: [id])

  salesmanId String
  salesman   User   @relation("SalesmanOrders", fields: [salesmanId], references: [id])

  addressId String?
  address   Address? @relation(fields: [addressId], references: [id])

  items    OrderItem[]
  tracking OrderTracking[]
  riderDeliveryJobs RiderDeliveryJob[]

  @@index([customerId])
  @@index([salesmanId])
  @@index([status])
  @@index([orderNumber])
}

// Order item model
model OrderItem {
  id        String   @id @default(cuid())
  quantity  Int
  price     Float // Price at time of order
  total     Float
  itemName  String? // Store item name at time of order
  itemType  String   @default("PRODUCT") // PRODUCT or CAR_PART
  createdAt DateTime @default(now())

  // Relations
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Can reference either Product or CarPart
  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  carPartId String?
  carPart   CarPart? @relation(fields: [carPartId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([carPartId])
}

// Order tracking model
model OrderTracking {
  id          String      @id @default(cuid())
  status      OrderStatus
  description String?
  location    String?
  createdAt   DateTime    @default(now())

  // Relations
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Review model
model Review {
  id         String   @id @default(cuid())
  rating     Int // 1-5
  title      String?
  comment    String?
  images     String[]
  isVerified Boolean  @default(false) // Verified purchase
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([rating])
}

// ================================
// Car and Car Parts Models
// ================================

// Car model - represents a vehicle by number plate
model Car {
  id          String   @id @default(cuid())
  numberPlate String   @unique // e.g., "CAB-1234", "WP-AB-5678"
  make        String // e.g., Toyota, Honda, Nissan
  model       String // e.g., Corolla, Civic, Sunny
  year        Int // e.g., 2020
  engineType  String? // e.g., "1.8L Petrol", "2.0L Diesel"
  color       String?
  vinNumber   String?  @unique // Vehicle Identification Number
  description String?
  images      String[] // Car images
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  parts CarPart[]

  @@index([numberPlate])
  @@index([make, model])
  @@index([year])
}

// Car Part model - parts available for specific cars
model CarPart {
  id            String   @id @default(cuid())
  name          String // e.g., "Front Brake Pad Set"
  description   String?
  partNumber    String? // Manufacturer part number
  price         Float
  discountPrice Float?
  stock         Int      @default(0)
  condition     String   @default("NEW") // NEW, USED, REFURBISHED
  images        String[]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  carId String
  car   Car    @relation(fields: [carId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  sellerId String
  seller   User   @relation("SellerCarParts", fields: [sellerId], references: [id], onDelete: Cascade)

  // Cart items containing this car part
  cartItems  CartItem[]

  // Order items containing this car part
  orderItems OrderItem[]

  wishlistItems WishlistItem[]

  @@index([carId])
  @@index([categoryId])
  @@index([sellerId])
  @@index([name])
  @@index([partNumber])
}

// OTP for forgot-password flow
model PasswordResetOtp {
  id        String   @id @default(cuid())
  email     String
  otpHash   String   // bcrypt hash of the 6-digit OTP
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

// ================================
// Rider Delivery Models
// ================================

model RiderDeliveryPartner {
  id                    Int       @id @default(autoincrement())
  email                 String    @unique @db.VarChar(255)
  passwordHash          String    @map("password_hash") @db.VarChar(255)
  fullName              String    @map("full_name") @db.VarChar(255)
  phone                 String    @db.VarChar(20)
  vehicleType           String?   @map("vehicle_type") @db.VarChar(50)
  vehicleNumber         String?   @map("vehicle_number") @db.VarChar(50)
  profilePhotoUrl       String?   @map("profile_photo_url")
  bio                   String?
  address               String?
  emergencyContactName  String?   @map("emergency_contact_name") @db.VarChar(255)
  emergencyContactPhone String?   @map("emergency_contact_phone") @db.VarChar(20)
  pushToken             String?   @map("push_token")
  pushPlatform          String?   @map("push_platform") @db.VarChar(20)
  pushTokenUpdatedAt    DateTime? @map("push_token_updated_at")
  status                String    @default("offline") @db.VarChar(20)
  currentLatitude       Decimal?  @map("current_latitude") @db.Decimal(10, 8)
  currentLongitude      Decimal?  @map("current_longitude") @db.Decimal(11, 8)
  rating                Decimal   @default(0.00) @db.Decimal(3, 2)
  totalDeliveries       Int       @default(0) @map("total_deliveries")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @map("updated_at")

  refreshTokens RiderRefreshToken[]
  jobs          RiderDeliveryJob[]
  statusLogs    RiderJobStatusLog[]
  tracking      RiderJobTracking[]
  proofs        RiderProofOfDelivery[]
  offers        RiderDeliveryRequestOffer[]

  @@index([email], map: "idx_rider_partners_email")
  @@index([status], map: "idx_rider_partners_status")
  @@map("rider_delivery_partners")
}

model RiderRefreshToken {
  id        Int      @id @default(autoincrement())
  partnerId Int      @map("partner_id")
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  partner RiderDeliveryPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([token], map: "idx_rider_refresh_tokens_token")
  @@index([partnerId], map: "idx_rider_refresh_tokens_partner")
  @@map("rider_refresh_tokens")
}

model RiderDeliveryJob {
  id                    Int       @id @default(autoincrement())
  partnerId             Int?      @map("partner_id")
  marketplaceOrderId    String?   @map("marketplace_order_id")
  orderNumber           String    @unique @map("order_number") @db.VarChar(100)
  customerName          String    @map("customer_name") @db.VarChar(255)
  customerPhone         String    @map("customer_phone") @db.VarChar(20)
  pickupAddress         String    @map("pickup_address")
  pickupLatitude        Decimal   @map("pickup_latitude") @db.Decimal(10, 8)
  pickupLongitude       Decimal   @map("pickup_longitude") @db.Decimal(11, 8)
  pickupContactName     String?   @map("pickup_contact_name") @db.VarChar(255)
  pickupContactPhone    String?   @map("pickup_contact_phone") @db.VarChar(20)
  dropoffAddress        String    @map("dropoff_address")
  dropoffLatitude       Decimal   @map("dropoff_latitude") @db.Decimal(10, 8)
  dropoffLongitude      Decimal   @map("dropoff_longitude") @db.Decimal(11, 8)
  distanceKm            Decimal?  @map("distance_km") @db.Decimal(6, 2)
  paymentAmount         Decimal   @map("payment_amount") @db.Decimal(10, 2)
  packageWeight         Decimal?  @map("package_weight") @db.Decimal(8, 2)
  packageType           String?   @map("package_type") @db.VarChar(80)
  packageNotes          String?   @map("package_notes")
  paymentType           String    @default("PREPAID") @map("payment_type") @db.VarChar(30)
  itemsDescription      String?   @map("items_description")
  specialInstructions   String?   @map("special_instructions")
  status                String    @default("pending") @db.VarChar(30)
  createdAt             DateTime  @default(now()) @map("created_at")
  assignedAt            DateTime? @map("assigned_at")
  acceptedAt            DateTime? @map("accepted_at")
  arrivedAtPickupAt     DateTime? @map("arrived_at_pickup_at")
  pickedUpAt            DateTime? @map("picked_up_at")
  arrivedAtDropoffAt    DateTime? @map("arrived_at_dropoff_at")
  deliveredAt           DateTime? @map("delivered_at")
  failedAt              DateTime? @map("failed_at")
  updatedAt             DateTime  @default(now()) @map("updated_at")

  partner         RiderDeliveryPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  marketplaceOrder Order?               @relation(fields: [marketplaceOrderId], references: [id], onDelete: SetNull)
  statusLogs      RiderJobStatusLog[]
  tracking        RiderJobTracking[]
  proof           RiderProofOfDelivery?
  offers          RiderDeliveryRequestOffer[]

  @@index([status], map: "idx_rider_jobs_status")
  @@index([partnerId], map: "idx_rider_jobs_partner")
  @@index([orderNumber], map: "idx_rider_jobs_order_number")
  @@index([marketplaceOrderId], map: "idx_rider_jobs_marketplace_order")
  @@map("rider_delivery_jobs")
}

model RiderJobStatusLog {
  id        Int      @id @default(autoincrement())
  jobId     Int      @map("job_id")
  partnerId Int?     @map("partner_id")
  status    String   @db.VarChar(30)
  reason    String?
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  createdAt DateTime @default(now()) @map("created_at")

  job     RiderDeliveryJob      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  partner RiderDeliveryPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  @@map("rider_job_status_logs")
}

model RiderJobTracking {
  id         Int      @id @default(autoincrement())
  jobId      Int      @map("job_id")
  partnerId  Int      @map("partner_id")
  latitude   Decimal  @db.Decimal(10, 8)
  longitude  Decimal  @db.Decimal(11, 8)
  accuracy   Decimal? @db.Decimal(6, 2)
  speed      Decimal? @db.Decimal(6, 2)
  heading    Decimal? @db.Decimal(5, 2)
  recordedAt DateTime @default(now()) @map("recorded_at")

  job     RiderDeliveryJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  partner RiderDeliveryPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([jobId], map: "idx_rider_tracking_job")
  @@index([recordedAt], map: "idx_rider_tracking_recorded_at")
  @@map("rider_job_tracking")
}

model RiderProofOfDelivery {
  id                Int      @id @default(autoincrement())
  jobId             Int      @unique @map("job_id")
  partnerId         Int      @map("partner_id")
  photoUrl          String?  @map("photo_url")
  signatureData     String?  @map("signature_data")
  recipientName     String?  @map("recipient_name") @db.VarChar(255)
  notes             String?
  deliveryLatitude  Decimal? @map("delivery_latitude") @db.Decimal(10, 8)
  deliveryLongitude Decimal? @map("delivery_longitude") @db.Decimal(11, 8)
  createdAt         DateTime @default(now()) @map("created_at")

  job     RiderDeliveryJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  partner RiderDeliveryPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("rider_proof_of_delivery")
}

model RiderDeliveryRequestOffer {
  id                 Int       @id @default(autoincrement())
  jobId              Int       @map("job_id")
  partnerId          Int       @map("partner_id")
  offerStatus        String    @map("offer_status") @db.VarChar(20)
  distanceToPickupKm Decimal?  @map("distance_to_pickup_km") @db.Decimal(8, 3)
  offeredAt          DateTime  @default(now()) @map("offered_at")
  expiresAt          DateTime  @map("expires_at")
  respondedAt        DateTime? @map("responded_at")
  responseReason     String?   @map("response_reason")

  job     RiderDeliveryJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  partner RiderDeliveryPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([jobId], map: "idx_rider_dispatch_offers_job_id")
  @@index([partnerId], map: "idx_rider_dispatch_offers_partner_id")
  @@index([offerStatus, expiresAt], map: "idx_rider_dispatch_offers_status")
  @@map("rider_delivery_request_offers")
}
