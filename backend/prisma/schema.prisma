// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enum for user roles
enum UserRole {
  CUSTOMER
  SALESMAN
}

// Enum for authentication provider
enum AuthProvider {
  EMAIL
  GOOGLE
}

// User model
model User {
  id           String       @id @default(cuid())
  email        String       @unique
  password     String? // Nullable for Google auth users
  name         String?
  phone        String?
  avatar       String?
  role         UserRole     @default(CUSTOMER)
  authProvider AuthProvider @default(EMAIL)
  googleId     String?      @unique
  isVerified   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  addresses Address[]
  orders    Order[]        @relation("CustomerOrders")
  cart      CartItem[]
  wishlist  WishlistItem[]
  reviews   Review[]

  // Salesman specific relations
  products    Product[] @relation("SalesmanProducts")
  salesOrders Order[]   @relation("SalesmanOrders")
  store       Store?
  carParts    CarPart[] @relation("SellerCarParts")

  @@index([email])
  @@index([role])
}

// Store model for salesmen
model Store {
  id          String   @id @default(cuid())
  name        String
  description String?
  logo        String?
  banner      String?
  address     String?
  phone       String?
  rating      Float    @default(0)
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  ownerId  String    @unique
  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([ownerId])
}

// Product model
model Product {
  id            String   @id @default(cuid())
  name          String
  description   String?
  price         Float
  discountPrice Float?
  sku           String?  @unique
  stock         Int      @default(0)
  images        String[]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  salesmanId String
  salesman   User   @relation("SalesmanProducts", fields: [salesmanId], references: [id], onDelete: Cascade)

  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  orderItems    OrderItem[]
  reviews       Review[]

  // Vehicle compatibility
  compatibleVehicles VehicleCompatibility[]

  @@index([categoryId])
  @@index([salesmanId])
  @@index([storeId])
  @@index([name])
}

// Category model
model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  icon        String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  products Product[]
  carParts CarPart[]

  @@index([parentId])
}

// Vehicle compatibility for parts
model VehicleCompatibility {
  id        String  @id @default(cuid())
  make      String // e.g., Toyota, Honda
  model     String // e.g., Camry, Civic
  yearStart Int // Starting year
  yearEnd   Int? // Ending year (null means current)
  engine    String? // Engine type if specific

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([make, model])
  @@index([productId])
}

// Address model
model Address {
  id         String   @id @default(cuid())
  label      String? // e.g., "Home", "Office"
  street     String
  city       String
  state      String
  postalCode String
  country    String   @default("Sri Lanka")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

// Cart item model
model CartItem {
  id        String   @id @default(cuid())
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// Wishlist item model
model WishlistItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Relations
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// Order status enum
enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

// Payment status enum
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// Order model - represents a customer order for items from a single seller
model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique @default(cuid())
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod String?
  subtotal      Float
  deliveryFee   Float         @default(0)
  discount      Float         @default(0)
  total         Float
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  customerId String
  customer   User   @relation("CustomerOrders", fields: [customerId], references: [id])

  salesmanId String
  salesman   User   @relation("SalesmanOrders", fields: [salesmanId], references: [id])

  addressId String?
  address   Address? @relation(fields: [addressId], references: [id])

  items    OrderItem[]
  tracking OrderTracking[]

  @@index([customerId])
  @@index([salesmanId])
  @@index([status])
  @@index([orderNumber])
}

// Order item model
model OrderItem {
  id        String   @id @default(cuid())
  quantity  Int
  price     Float // Price at time of order
  total     Float
  itemName  String? // Store item name at time of order
  itemType  String   @default("PRODUCT") // PRODUCT or CAR_PART
  createdAt DateTime @default(now())

  // Relations
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Can reference either Product or CarPart
  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  carPartId String?
  carPart   CarPart? @relation(fields: [carPartId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([carPartId])
}

// Order tracking model
model OrderTracking {
  id          String      @id @default(cuid())
  status      OrderStatus
  description String?
  location    String?
  createdAt   DateTime    @default(now())

  // Relations
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Review model
model Review {
  id         String   @id @default(cuid())
  rating     Int // 1-5
  title      String?
  comment    String?
  images     String[]
  isVerified Boolean  @default(false) // Verified purchase
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([rating])
}

// ================================
// Car and Car Parts Models
// ================================

// Car model - represents a vehicle by number plate
model Car {
  id          String   @id @default(cuid())
  numberPlate String   @unique // e.g., "CAB-1234", "WP-AB-5678"
  make        String // e.g., Toyota, Honda, Nissan
  model       String // e.g., Corolla, Civic, Sunny
  year        Int // e.g., 2020
  engineType  String? // e.g., "1.8L Petrol", "2.0L Diesel"
  color       String?
  vinNumber   String?  @unique // Vehicle Identification Number
  description String?
  images      String[] // Car images
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  parts CarPart[]

  @@index([numberPlate])
  @@index([make, model])
  @@index([year])
}

// Car Part model - parts available for specific cars
model CarPart {
  id            String   @id @default(cuid())
  name          String // e.g., "Front Brake Pad Set"
  description   String?
  partNumber    String? // Manufacturer part number
  price         Float
  discountPrice Float?
  stock         Int      @default(0)
  condition     String   @default("NEW") // NEW, USED, REFURBISHED
  images        String[]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  carId String
  car   Car    @relation(fields: [carId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  sellerId String
  seller   User   @relation("SellerCarParts", fields: [sellerId], references: [id], onDelete: Cascade)

  // Order items containing this car part
  orderItems OrderItem[]

  @@index([carId])
  @@index([categoryId])
  @@index([sellerId])
  @@index([name])
  @@index([partNumber])
}

// OTP for forgot-password flow
model PasswordResetOtp {
  id        String   @id @default(cuid())
  email     String
  otpHash   String   // bcrypt hash of the 6-digit OTP
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}
